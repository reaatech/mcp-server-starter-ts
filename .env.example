# Server Configuration
PORT=8080
NODE_ENV=development

# Authentication
# Required in production. Generate with: openssl rand -hex 32
API_KEY=

# Auth mode: 'api-key' (x-api-key header) or 'bearer' (Authorization header)
AUTH_MODE=api-key
AUTH_BYPASS_IN_DEV=true

# OpenTelemetry Configuration
# OTLP endpoint for traces and metrics (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mcp-server
OTEL_RESOURCE_ATTRIBUTES=

# Idempotency
# TTL in milliseconds for idempotency cache (default: 5 minutes)
IDEMPOTENCY_TTL_MS=300000

# Rate Limiting
# Requests per minute per client (default: 60)
RATE_LIMIT_RPM=60

# Logging
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Session Configuration
# Session timeout in milliseconds (default: 30 minutes)
SESSION_TIMEOUT_MS=1800000

# Sanitization
# Optional comma-separated literal patterns to strip from string tool inputs
SANITIZATION_DENY_PATTERNS=
